{
  "name": "juijs-chart",
  "version": "2.6.12",
  "sideEffects": false,
  "description": "SVG-based JUI chart that can be used in the browser and Node.js. Support many types of charts. (Dashboard, Map, Topology, Full 3D)",
  "scripts": {
    "start": "npm run dev",
    "dev": "vite --config vite.config.mjs",
    "dist": "vite build --config vite.config.mjs",
    "test": "vitest run --config vite.config.mjs --passWithNoTests"
  },
  "main": "src/main.js",
  "files": [
    "bundles",
    "dist",
    "examples",
    "images",
